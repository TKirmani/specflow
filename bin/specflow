#!/usr/bin/env sh
# specflow — spec-driven development workflow helper.
#
# Subcommands:
#   init       Bootstrap spec-kit + progress tooling in the current project
#   progress   Report task completion across specs/*/tasks.md (pass --watch for live view)
#   version    Print version
#
# Run `specflow <subcommand> --help` for details.

set -eu

VERSION="0.1.0"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

say()  { printf '\033[1;34m[specflow]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[specflow]\033[0m %s\n' "$*" >&2; }
die()  { warn "$*"; exit 1; }

usage() {
  cat <<EOF
specflow $VERSION — spec-driven development workflow helper

USAGE
  specflow <command> [options]

COMMANDS
  init        Bootstrap spec-kit + progress tooling in the current project
  progress    Report task completion across specs/*/tasks.md
  version     Print version
  help        Show this message

Run 'specflow <command> --help' for command-specific options.
EOF
}

cmd_init() {
  AGENT="none"
  while [ $# -gt 0 ]; do
    case "$1" in
      --agent)     AGENT="$2"; shift 2 ;;
      --agent=*)   AGENT="${1#--agent=}"; shift ;;
      -h|--help)
        cat <<EOF
specflow init — bootstrap spec-driven development in the current project.

USAGE
  specflow init [--agent <claude|copilot|cursor|codex|gemini|none>]

WHAT IT DOES
  1. If .specify/ is absent, runs 'specify init --here --ai <agent>'
     (invoked via uvx if 'specify' is not globally installed).
  2. Ensures .sdd/ is in .gitignore for local progress state.
  3. Prints next-step guidance.

The progress reporter is 'specflow progress' — no files are dropped into
your project. This keeps specflow non-invasive and easy to upgrade.

EXAMPLES
  specflow init                 # agent-neutral bootstrap
  specflow init --agent cursor  # bootstrap with Cursor-specific artifacts
EOF
        exit 0 ;;
      *) die "unknown arg: $1" ;;
    esac
  done

  if [ -d .specify ]; then
    say "spec-kit already initialized (.specify/ exists) — skipping"
  else
    if command -v specify >/dev/null 2>&1; then
      SPECIFY="specify"
    elif command -v uvx >/dev/null 2>&1; then
      SPECIFY="uvx --from git+https://github.com/github/spec-kit.git specify"
    else
      die "Neither 'specify' nor 'uvx' is on PATH. Install uv: https://docs.astral.sh/uv/"
    fi
    say "running: $SPECIFY init --here --ai $AGENT"
    # shellcheck disable=SC2086
    $SPECIFY init --here --ai "$AGENT"
  fi

  if [ -f .gitignore ]; then
    grep -qxF '.sdd/' .gitignore || printf '\n.sdd/\n' >> .gitignore
  else
    printf '.sdd/\n' > .gitignore
  fi
  say "ensured .sdd/ is gitignored"

  cat <<EOF

Done. Next steps:
  specflow progress           # one-shot task report
  specflow progress --watch   # live TUI

Then drive your agent through the spec-kit flow:
  /speckit.specify → /speckit.plan → /speckit.tasks → /speckit.implement

For TDD gating, consider installing superpowers for your agent:
  https://github.com/obra/superpowers
EOF
}

cmd_progress() {
  HELPER="$SCRIPT_DIR/specflow-progress"
  [ -x "$HELPER" ] || die "progress helper not found at $HELPER"
  exec "$HELPER" "$@"
}

main() {
  if [ $# -eq 0 ]; then usage; exit 0; fi
  SUB="$1"; shift
  case "$SUB" in
    init)            cmd_init "$@" ;;
    progress)        cmd_progress "$@" ;;
    version|--version|-V) echo "specflow $VERSION" ;;
    help|-h|--help)  usage ;;
    *) warn "unknown command: $SUB"; usage; exit 2 ;;
  esac
}

main "$@"
